<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>latihan3_Farkhan Abdilah_TI-2B</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --ink: #0a0a0f;
      --cream: #f5f0e8;
      --gold: #c9a84c;
      --gold-light: #e8c96a;
      --rust: #c0432a;
      --teal: #1a6b72;
      --teal-light: #2a9ba6;
      --off-white: #faf8f4;
      --muted: #7a7570;
      --border: rgba(10,10,15,0.12);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--off-white);
      color: var(--ink);
      overflow-x: hidden;
    }

    .masthead {
      background: var(--ink);
      padding: 12px 0;
      text-align: center;
      border-bottom: 3px solid var(--gold);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .masthead-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
    }
    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 900;
      color: var(--cream);
      letter-spacing: -1px;
    }
    .logo span { color: var(--gold); }
    .dateline {
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 2px;
      text-transform: uppercase;
    }
    .edition-tag {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      color: var(--gold);
      border: 1px solid var(--gold);
      padding: 3px 10px;
      letter-spacing: 2px;
    }

    .nav-bar {
      background: var(--cream);
      border-bottom: 1px solid var(--border);
      padding: 0;
      overflow-x: auto;
      white-space: nowrap;
    }
    .nav-bar-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 32px;
      display: flex;
      gap: 0;
    }
    .nav-bar a {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      padding: 12px 18px;
      border-right: 1px solid var(--border);
      transition: background 0.2s, color 0.2s;
      position: relative;
    }
    .nav-bar a:first-child { border-left: 1px solid var(--border); }
    .nav-bar a:hover { background: var(--ink); color: var(--gold); }
    .nav-bar a.active { background: var(--gold); color: var(--ink); font-weight: 700; }


    .hero {
      background: linear-gradient(135deg, var(--ink) 0%, #1a1a2e 50%, #16213e 100%);
      padding: 64px 32px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a84c' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 1;
    }
    .hero-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 900;
      color: var(--cream);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .hero-text h1 em { color: var(--gold); font-style: italic; }
    .hero-text p {
      color: #8a8a9a;
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .hero-badge {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.4);
      color: var(--gold);
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 2px;
      padding: 8px 16px;
    }
    .hero-badge::before { content: '◈'; }

    /* ── IMAGE MAP CONTAINER ────────────────────────── */
    .map-wrapper {
      position: relative;
      border: 2px solid rgba(201,168,76,0.3);
      background: #111;
    }
    .map-wrapper img {
      width: 100%;
      height: auto;
      display: block;
      opacity: 0.85;
      transition: opacity 0.3s;
    }
    .map-wrapper:hover img { opacity: 1; }
    .map-label {
      position: absolute;
      top: -12px;
      left: 20px;
      background: var(--gold);
      color: var(--ink);
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 2px;
      padding: 4px 12px;
      font-weight: 700;
    }
    .map-hint {
      background: rgba(0,0,0,0.7);
      color: #8a8a9a;
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      padding: 8px 16px;
      letter-spacing: 1px;
      border-top: 1px solid rgba(201,168,76,0.2);
      display: flex;
      justify-content: space-between;
    }
    .map-hint span { color: var(--gold); }

    /* Highlight overlays for image map areas */
    .map-overlay {
      position: absolute;
      pointer-events: none;
      border: 2px solid var(--gold);
      opacity: 0;
      transition: opacity 0.3s;
    }
    area { cursor: pointer; }

    /* ── HYPERLINK SHOWCASE ─────────────────────────── */
    .section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 32px;
    }
    .section-header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 40px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    .section-num {
      font-family: 'Space Mono', monospace;
      font-size: 12px;
      color: var(--gold);
      letter-spacing: 3px;
    }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 700;
      color: var(--ink);
    }

    /* Link Cards */
    .link-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      background: var(--border);
    }
    .link-card {
      background: var(--off-white);
      padding: 28px;
      transition: transform 0.2s, box-shadow 0.2s;
      position: relative;
      overflow: hidden;
    }
    .link-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 3px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s;
    }
    .link-card:hover::before { transform: scaleX(1); }
    .link-card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(0,0,0,0.1); z-index: 1; }
    .card-tag {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
      display: inline-block;
      padding: 4px 8px;
    }
    .tag-blank { background: rgba(26,107,114,0.1); color: var(--teal); }
    .tag-self  { background: rgba(201,168,76,0.1); color: #a07820; }
    .tag-parent{ background: rgba(192,67,42,0.12); color: var(--rust); }
    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .card-desc {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
      margin-bottom: 20px;
    }
    .card-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 1px;
      text-decoration: none;
      padding: 10px 20px;
      border: 1.5px solid var(--ink);
      color: var(--ink);
      transition: all 0.2s;
    }
    .card-link:hover { background: var(--ink); color: var(--cream); }
    .card-link .arrow { transition: transform 0.2s; }
    .card-link:hover .arrow { transform: translateX(4px); }

    /* ── BERITA SECTION ─────────────────────────────── */
    .news-wrapper {
      background: var(--cream);
      border-top: 3px solid var(--ink);
      border-bottom: 3px solid var(--ink);
    }
    .news-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 64px 32px;
    }
    .news-layout {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 48px;
    }

    /* Scrollable news column */
    .news-scroll-box {
      height: 520px;
      overflow-y: auto;
      padding-right: 16px;
      scrollbar-width: thin;
      scrollbar-color: var(--gold) transparent;
    }
    .news-scroll-box::-webkit-scrollbar { width: 3px; }
    .news-scroll-box::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 0; }

    .news-article {
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
      animation: fadeSlide 0.5s ease both;
    }
    .news-article:first-child { padding-top: 0; }
    @keyframes fadeSlide {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .article-cat {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 8px;
    }
    .article-title {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 10px;
      color: var(--ink);
    }
    .article-title a {
      color: inherit;
      text-decoration: none;
      transition: color 0.2s;
    }
    .article-title a:hover { color: var(--teal); }
    .article-meta {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 1px;
      margin-bottom: 12px;
      display: flex;
      gap: 16px;
    }
    .article-body {
      font-size: 14px;
      line-height: 1.8;
      color: #3a3a3a;
    }
    .article-body p { margin-bottom: 10px; }
    .read-more {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 1.5px;
      color: var(--teal);
      text-decoration: none;
      margin-top: 8px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--teal-light);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .read-more:hover { color: var(--gold); border-color: var(--gold); }

    /* Sidebar */
    .news-sidebar { display: flex; flex-direction: column; gap: 0; }
    .sidebar-head {
      font-family: 'Space Mono', monospace;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--muted);
      padding-bottom: 12px;
      border-bottom: 2px solid var(--ink);
      margin-bottom: 0;
    }
    .sidebar-item {
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-item-num {
      font-family: 'Space Mono', monospace;
      font-size: 28px;
      font-weight: 700;
      color: rgba(10,10,15,0.07);
      line-height: 1;
      margin-bottom: 4px;
    }
    .sidebar-item-title {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 4px;
    }
    .sidebar-item-title a {
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }
    .sidebar-item-title a:hover { color: var(--teal); }
    .sidebar-item-date {
      font-family: 'Space Mono', monospace;
      font-size: 9px;
      color: var(--muted);
      letter-spacing: 1px;
    }

    /* ── BOOKMARK ANCHORS ───────────────────────────── */
    .bookmark-anchor {
      display: block;
      position: relative;
      top: -80px;
      visibility: hidden;
    }

    /* ── FOOTER ─────────────────────────────────────── */
    footer {
      background: var(--ink);
      color: var(--muted);
      text-align: center;
      padding: 32px;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      letter-spacing: 1.5px;
      border-top: 3px solid var(--gold);
    }
    footer a { color: var(--gold); text-decoration: none; }

    /* ── DIVIDER ────────────────────────────────────── */
    .editorial-rule {
      max-width: 1200px;
      margin: 0 auto 0;
      padding: 0 32px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .editorial-rule::before,
    .editorial-rule::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .rule-ornament {
      font-size: 20px;
      color: var(--gold);
      line-height: 1;
    }

    /* ── SCROLL PROGRESS ────────────────────────────── */
    .progress-bar {
      position: fixed;
      top: 0; left: 0;
      width: 0%;
      height: 3px;
      background: linear-gradient(90deg, var(--gold), var(--rust));
      z-index: 999;
      transition: width 0.1s;
    }

    /* ── RESPONSIVE ─────────────────────────────────── */
    @media (max-width: 900px) {
      .hero-inner, .link-grid, .news-layout { grid-template-columns: 1fr; }
      .hero-inner { gap: 40px; }
      .link-grid { gap: 1px; }
      .masthead-inner { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
